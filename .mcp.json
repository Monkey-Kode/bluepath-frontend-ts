{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_MCP_API_KEY}"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "Sanity": {
      "url": "https://mcp.sanity.io",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${SANITY_BLUEPATH_MCP_TOKEN}"
      }
    }
  }
}
