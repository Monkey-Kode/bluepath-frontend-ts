{
  "name": "bluepath",
  "version": "1.0.0",
  "private": true,
  "description": "bluepath",
  "author": "Jull Weber",
  "scripts": {
    "predev": "pnpm run sanity:typegen",
    "dev": "next dev",
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "sanity:typegen": "pnpm --dir ../bluepath-sanity exec sanity schema extract --enforce-required-fields --path ../bluepath-gatsby-ts/sanity.schema.json && sanity typegen generate"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "groq": "^5.25.1",
    "next": "^16.2.6",
    "next-sanity": "^12.4.5",
    "normalize.css": "^8.0.1",
    "polished": "^4.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanity-image": "^1.1.0",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.1",
    "typography": "^0.16.24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ]
  },
  "volta": {
    "node": "24.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/typography": "^0.16.9",
    "sanity": "^5.25.1",
    "typescript": "^6.0.3"
  }
}
