{
  "name": "bluepath",
  "version": "1.0.0",
  "private": true,
  "description": "bluepath",
  "author": "Jull Weber",
  "scripts": {
    "predev": "pnpm run sanity:typegen",
    "dev": "next dev",
    "dev:netlify": "netlify dev",
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "sanity:typegen": "pnpm --dir ../bluepath-sanity exec sanity schema extract --enforce-required-fields --path ../bluepath-gatsby-ts/sanity.schema.json && sanity typegen generate"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^1.16.10",
    "@portabletext/react": "^6.2.0",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "classnames": "^2.5.1",
    "framer-motion": "^12.38.0",
    "get-youtube-id": "^1.0.1",
    "groq": "^5.25.1",
    "next": "^16.2.6",
    "next-sanity": "^12.4.5",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-intersection-observer": "^10.0.3",
    "sanity-image": "^1.1.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0"
  },
  "packageManager": "pnpm@11.1.2",
  "volta": {
    "node": "24.15.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/google.maps": "^3.64.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "sanity": "^5.25.1",
    "typescript": "^6.0.3"
  }
}
